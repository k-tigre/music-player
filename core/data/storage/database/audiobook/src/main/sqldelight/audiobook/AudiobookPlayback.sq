CREATE TABLE AudiobookPlaybackPosition (
    book_id    INTEGER NOT NULL PRIMARY KEY,
    chapter_id INTEGER NOT NULL,
    position_ms INTEGER NOT NULL DEFAULT 0
);

upsertPosition:
INSERT OR REPLACE INTO AudiobookPlaybackPosition(book_id, chapter_id, position_ms)
VALUES(?, ?, ?);

getPosition:
SELECT chapter_id, position_ms
FROM AudiobookPlaybackPosition
WHERE book_id = ?;
