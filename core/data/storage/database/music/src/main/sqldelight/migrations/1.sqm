BEGIN TRANSACTION;
CREATE TABLE Queue_TMP( 
id INTEGER PRIMARY KEY AUTOINCREMENT,
status INTEGER AS PlaybackQueueStorage.QueueItem.State NOT NULL DEFAULT 0,
song_id INTEGER NOT NULL,
sort_order INTEGER NOT NULL DEFAULT (RANDOM())
);
INSERT INTO Queue_TMP SELECT id, status, song_id, 0 FROM Queue;
DROP TABLE Queue;
ALTER TABLE Queue_TMP RENAME TO Queue;
COMMIT;